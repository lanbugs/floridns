DATABASE_URL=postgresql+asyncpg://pdns:pdns@localhost/pdnsui

# Initial admin (nur beim ersten Start genutzt, wenn keine User in der DB existieren)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=changeme
INITIAL_ADMIN_EMAIL=admin@example.com

PDNS_API_URL=http://localhost:8081
PDNS_API_KEY=your-pdns-api-key
PDNS_SERVER_ID=localhost

SECRET_KEY=changeme-use-at-least-32-chars-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
LOG_FORMAT=json

# In production (HTTPS): set to true (default)
# In development (HTTP/localhost): must be false, otherwise the refresh token cookie is not sent
COOKIE_SECURE=false

# Optional: Fernet key for encrypting sensitive settings in the DB (ldap_config, oidc_config, etc.)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to store settings as plaintext (not recommended for production)
SETTINGS_ENCRYPTION_KEY=

# WebAuthn / Passkeys
# RP ID must match the domain users access the app on (no port, no scheme)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=FloriDNS
# Origin must include scheme and port if non-standard
WEBAUTHN_ORIGIN=http://localhost:5173
